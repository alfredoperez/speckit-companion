{
  "chat.promptFilesRecommendations": {
    "sdd.specify": true,
    "sdd.plan": true,
    "sdd.tasks": true,
    "sdd.implement": true,
    "sdd.auto": true,
    "sdd.continue": true,
    "sdd.status": true
  },
  "chat.tools.terminal.autoApprove": {
