        {
          "name": "plan",
          "label": "Plan",
          "command": "sdd:plan",
          "file": "plan.md"
        },
        {
          "name": "tasks",
          "label": "Tasks",
          "command": "sdd:tasks",
          "file": "tasks.md"
        },
        {
          "name": "implement",
          "label": "Implement",
          "command": "sdd:implement",
          "actionOnly": true
        }
