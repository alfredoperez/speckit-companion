node_modules/
dist/
out/
*.vsix
.vscode-test/
*.log
.DS_Store
.env

# SDD implement write-ahead journal — transient, materialized into .spec-context.json
.spec-context.events.jsonl
.spec-context.events.lock
.env.local
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json



# 测试相关
coverage/
*.snap.tmp
.nyc_output/

# Storybook build output (regenerated by `npm run build-storybook`)
storybook-static/

# Serena MCP per-project cache (machine-generated, includes large .pkl dumps)
.serena/

# Transient prompt artifact written by the SpecKit Companion extension at dispatch
.claude/speckit-companion-prompt.md

# Local dev-install artifacts from `specify extension add ./speckit-extension --dev`
# (machine-specific symlinks + caches; the source of truth is speckit-extension/)
.specify/extensions/**/.specify-dev/
.specify/extensions/.cache/
# Generated spec-kit command emissions — the installed copy of speckit-extension/
# plus every per-agent `speckit.*` / `speckit-*` command that the `specify init`
# / `specify extension add` / `preset add` installers write into the agent dirs.
# All regenerated from speckit-extension/ + the spec-kit core on each install and
# never hand-edited, so tracking them only produced churn (every install rewrote
# them). Regenerate locally with `specify init` when you need the IDE-chat
# fixtures. The hand-maintained `eval-speckit-extension` skill and the `.github`
# CI files / non-speckit prompts don't match these globs and stay tracked.
.specify/extensions/companion/
.claude/skills/speckit-*/
.cursor/skills/speckit-*/
.agents/skills/speckit-*/
.gemini/commands/speckit.*
.qwen/commands/speckit.*
.github/agents/speckit.*
.github/prompts/speckit.*
.windsurf/workflows/speckit.*

# Local-only demo spec dirs (underscore-prefixed under specs/)
specs/_*/

# Canonical demo testing specs are committed at a fixed baseline (specified /
# planned / tasked-out states). They are tracked, but local edits must NOT be
# committed — see CLAUDE.md "Demo testing specs". Revert with `git restore`.
!specs/_demo-specified/
!specs/_demo-planned/
!specs/_demo-tasked/
!specs/_00_demo-specified/
!specs/_01_demo-planned/
!specs/_02_demo-tasked/
