{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": [
      "jest",
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "webview/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}