{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 1,
      "content": {
        "json": "# SpecKit Companion — Telemetry\nAnonymous, PII-free adoption metrics. Use the time range below to scope every chart.\n\n_Note: `extension.activated` counts window loads, not people — for real adoption lean on `spec.created` / `spec.completed`, the active-installs trend, and the engagement events (`spec.opened`, living-spec actions, `steering.opened`). The engagement tiles stay empty until those events ship._"
      },
      "name": "title"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
            "id": "param-timerange",
            "version": "KqlParameterItem/1.0",
            "name": "TimeRange",
            "label": "Time range",
            "type": 4,
            "isRequired": true,
            "value": { "durationMs": 2592000000 },
            "typeSettings": {
              "selectableValues": [
                { "durationMs": 86400000 },
                { "durationMs": 604800000 },
                { "durationMs": 2592000000 },
                { "durationMs": 7776000000 }
              ]
            }
          }
        ],
        "style": "pills",
        "queryType": 0,
        "resourceType": "microsoft.insights/components"
      },
      "name": "parameters"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | summarize ActiveInstalls = dcount(user_Id) by bin(timestamp, 7d) | order by timestamp asc",
              "size": 1,
              "title": "Active installs per week (is usage growing?)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "timechart"
            },
            "name": "active-installs-trend"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | extend providerId = tostring(customDimensions.providerId) | where isnotempty(providerId) | summarize Events = count() by providerId | order by Events desc",
              "size": 1,
              "title": "AI provider usage",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "piechart"
            },
            "customWidth": "50",
            "name": "provider-usage"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name endswith \"extension.activated\" | extend Workflow = tostring(customDimensions.defaultWorkflow) | summarize Activations = count() by Workflow | order by Activations desc",
              "size": 1,
              "title": "Default workflow (Companion vs spec-kit)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "piechart"
            },
            "customWidth": "50",
            "name": "workflow-split"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name endswith \"extension.activated\" | extend Installed = iff(tostring(customDimensions.companionInstalled) == \"true\", \"companion installed\", \"not installed\") | summarize Activations = count() by Installed | order by Activations desc",
              "size": 1,
              "title": "Install rate — activations with the spec-kit extension present",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "piechart"
            },
            "customWidth": "50",
            "name": "install-rate"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name endswith \"companion.installPrompt\" | extend Action = tostring(customDimensions.action), Surface = tostring(customDimensions.surface) | summarize Shown = countif(Action == \"shown\"), Clicked = countif(Action == \"clicked\") by Surface | extend ConversionPct = round(100.0 * Clicked / Shown, 1) | order by Surface asc",
              "size": 1,
              "title": "Install-prompt conversion (banner shown → Install clicked)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "table"
            },
            "customWidth": "50",
            "name": "install-conversion"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name endswith \"phase.dispatched\" | extend Phase = tostring(customDimensions.phase) | summarize Dispatches = count() by Phase | order by Dispatches desc",
              "size": 1,
              "title": "Pipeline phases dispatched",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "phases"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name endswith \"extension.activated\" | summarize Activations = count() by client_CountryOrRegion | order by Activations desc",
              "size": 1,
              "title": "Where users are (by country/region)",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "geography"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | summarize Events = count() by client_OS | order by Events desc",
              "size": 1,
              "title": "Operating system",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "piechart"
            },
            "customWidth": "50",
            "name": "os-split"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name has_any (\"spec.created\", \"spec.completed\", \"spec.archived\") | extend Event = tostring(split(name, \"/\")[-1]) | summarize Count = count() by bin(timestamp, 1d), Event | order by timestamp asc",
              "size": 1,
              "title": "Spec lifecycle over time",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "timechart"
            },
            "name": "spec-funnel"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name has_any (\"spec.opened\", \"livingSpec.opened\", \"livingSpec.drift\", \"livingSpec.sync\", \"steering.opened\") | extend Event = tostring(split(name, \"/\")[-1]) | summarize Count = count() by bin(timestamp, 1d), Event | order by timestamp asc",
              "size": 1,
              "title": "Engagement over time (opens · living-spec actions · steering) — populates once #531 ships",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "timechart"
            },
            "name": "engagement-trend"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | where name has_any (\"spec.opened\", \"livingSpec.opened\", \"livingSpec.drift\", \"livingSpec.sync\", \"steering.opened\") | extend Event = tostring(split(name, \"/\")[-1]) | summarize Count = count() by Event | order by Count desc",
              "size": 1,
              "title": "Engagement totals (opens · living-spec actions · steering) — populates once #531 ships",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "barchart"
            },
            "customWidth": "50",
            "name": "engagement-totals"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "customEvents | extend Event = tostring(split(name, \"/\")[-1]) | project timestamp, Event, customDimensions, client_CountryOrRegion, client_OS, application_Version | order by timestamp desc | take 100",
              "size": 1,
              "title": "Recent events",
              "timeContextFromParameter": "TimeRange",
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "/subscriptions/3551e0ff-31b6-45a2-8038-c37c50718bad/resourceGroups/speckit-rg/providers/microsoft.insights/components/speckit-companion-telemetry"
              ],
              "visualization": "table"
            },
            "customWidth": "50",
            "name": "recent-events"
          }
        ]
      },
      "name": "charts-group"
    }
  ],
  "fallbackResourceIds": [
    "azure monitor"
  ],
  "$schema": "https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"
}
