{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckit-companion/spec-context.schema.json",
  "title": "SpecContext",
  "type": "object",
  "additionalProperties": true,
  "required": ["workflow", "specName", "branch", "currentStep", "status", "history"],
  "properties": {
    "workflow": { "type": "string", "minLength": 1 },
    "specName": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "selectedAt": { "type": "string", "format": "date-time" },
    "currentStep": {
      "type": "string",
      "enum": ["specify", "clarify", "plan", "tasks", "analyze", "implement"]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft", "specifying", "specified",
        "planning", "planned",
        "tasking", "ready-to-implement",
        "implementing", "implemented", "completed", "archived"
      ]
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/historyEntry" }
    },
    "reviewComments": {
      "type": "array",
      "items": { "$ref": "#/$defs/reviewComment" }
    },
    "last_action": { "type": "string" },
    "profile": { "type": "string", "enum": ["standard", "turbo"] },
    "telemetryInstanceId": { "type": "string" },
    "task_summaries": { "type": "object" },
    "step_summaries": { "type": "object" },
    "intent": { "type": "string" },
    "approach": { "type": "string" },
    "expectations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decisions": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["decision"],
            "properties": {
              "decision": { "type": "string", "minLength": 1 },
              "why": { "type": "string" },
              "rejected": { "type": "string" }
            }
          }
        ]
      }
    },
    "concerns": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["note"],
            "properties": {
              "note": { "type": "string", "minLength": 1 },
              "step": { "type": "string" },
              "kind": { "type": "string" },
              "task": { "type": "string" }
            }
          }
        ]
      }
    },
    "verified": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["what"],
            "properties": {
              "what": { "type": "string", "minLength": 1 },
              "result": { "type": "string" },
              "command": { "type": "string" },
              "warnings": { "type": "array", "items": { "type": "string" } }
            }
          }
        ]
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tasks": { "type": "array", "items": { "type": "string" } },
          "tests": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "classification": {
      "type": "object",
      "required": ["verdict"],
      "properties": {
        "projectedFiles": { "type": "integer", "minimum": 0 },
        "projectedTasks": { "type": "integer", "minimum": 0 },
        "scopeSignal": { "type": "string", "enum": ["larger", "smaller", "none"] },
        "verdict": { "type": "string", "enum": ["simple", "normal", "oversized"] }
      }
    }
  },
  "$defs": {
    "reviewComment": {
      "type": "object",
      "required": ["id", "doc", "anchor", "comment", "status", "createdAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "doc": { "type": "string", "enum": ["spec", "plan", "tasks"] },
        "anchor": {
          "type": "object",
          "required": ["heading", "blockText", "line"],
          "properties": {
            "heading": { "type": ["string", "null"] },
            "blockText": { "type": "string" },
            "line": { "type": "integer", "minimum": 0 }
          }
        },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "applied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "historyEntry": {
      "type": "object",
      "required": ["step", "substep", "kind", "by", "at"],
      "properties": {
        "step": {
          "type": "string",
          "enum": ["specify", "clarify", "plan", "tasks", "analyze", "implement"]
        },
        "substep": { "type": ["string", "null"] },
        "task": { "type": "string" },
        "kind": { "type": "string", "enum": ["start", "complete"] },
        "by": { "type": "string", "enum": ["extension", "user", "cli", "ai", "derive"] },
        "at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
